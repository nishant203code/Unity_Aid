# ============================================
#  UnityAid — Root .gitignore
# ============================================

# ─── Credentials & Secrets ───
.env
.env.*
!.env.example
.env.local
.env.development
.env.production
*.secret
*.pem
*.p12
*.key
*.keystore
*.jks
serviceAccountKey.json
service-account*.json
*-credentials.json
gcloud-*.json
.runtimeconfig.json
.firebaserc

# Firebase project-specific config files
# (google-services.json contains API keys & OAuth client IDs)
**/google-services.json
**/GoogleService-Info.plist

# ─── Dependencies ───
node_modules/
.pnp/
.pnp.js
venv/
.venv/
__pycache__/
*.pyc

# ─── Build Outputs ───
dist/
build/
[Bb]uild/
[Bb]uilds/
out/
*.apk
*.aab
*.aar
*.ipa

# ─── OS Files ───
.DS_Store
.DS_Store?
._*
Thumbs.db
ehthumbs.db
Desktop.ini
$RECYCLE.BIN/
*~

# ─── Logs ───
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
firebase-debug.log
firestore-debug.log
pubsub-debug.log
ui-debug.log
debug_output.txt
analyze_output.txt
analysis.log

# ─── IDE & Editor ───
.vscode/
.idea/
*.iml
*.ipr
*.iws
*.swp
*.swo
.gradle/

# ─── Archives ───
*.zip
*.tar.gz
*.rar
*.7z

# ─── Flutter / Dart ───
**/doc/api/
**/ios/Flutter/.last_build_id
.dart_tool/
.flutter-plugins
.flutter-plugins-dependencies
.packages
.pub-cache/
.pub/
pubspec.lock
coverage/
*.symbols
*.map.json

# ─── Android ───
**/android/.gradle/
**/android/app/debug/
**/android/app/profile/
**/android/app/release/
**/android/captures/
**/android/gradlew
**/android/gradlew.bat
**/local.properties

# ─── iOS ───
**/ios/Pods/
**/ios/Flutter/Flutter.framework
**/ios/Flutter/Generated.xcconfig
**/ios/Flutter/flutter_export_environment.sh
Pods/
*.xcworkspace/
*.xcodeproj/

# ─── macOS ───
**/macos/Flutter/GeneratedPluginRegistrant.swift

# ─── Firebase Functions ───
backend/functions/lib/
*.js.map
typings/

# ─── DataConnect Generated Code ───
**/dataconnect_generated/

# ─── Temp / Cache ───
temp/
.cache/
.temp/
*.tmp