<?xml version="1.0" encoding="utf-8"?>
<network-security-config>
    <!-- Allow cleartext for local testing if needed -->
    <base-config cleartextTrafficPermitted="false">
        <trust-anchors>
            <!-- Trust preinstalled CAs -->
            <certificates src="system" />
            <!-- Also trust user-added CAs (needed on some Android devices) -->
            <certificates src="user" />
        </trust-anchors>
    </base-config>

    <!-- Explicitly trust bitmind.io -->
    <domain-config cleartextTrafficPermitted="false">
        <domain includeSubdomains="true">bitmind.io</domain>
        <trust-anchors>
            <certificates src="system" />
            <certificates src="user" />
        </trust-anchors>
    </domain-config>
</network-security-config>
