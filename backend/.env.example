# ─── Backend Environment Variables ───
# This file contains the actual project keys for UnityAid.
# Your friends can use this file directly.

# Firebase Project
FIREBASE_PROJECT_ID=unity-aid-e8db3
FIREBASE_STORAGE_BUCKET=unity-aid-e8db3.firebasestorage.app

# Firebase Emulators (used for local development)
FIRESTORE_EMULATOR_HOST=localhost:8080
FIREBASE_AUTH_EMULATOR_HOST=localhost:9099
FIREBASE_STORAGE_EMULATOR_HOST=localhost:9199

# Google Cloud Service Account
# Download from: Firebase Console → Project Settings → Service Accounts → Generate New Private Key
# Place the file at: backend/serviceAccountKey.json
GOOGLE_APPLICATION_CREDENTIALS=./serviceAccountKey.json
